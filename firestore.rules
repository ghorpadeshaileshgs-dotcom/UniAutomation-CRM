rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Users: can read if signed in; can only write own document
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // All operational collections — signed-in user only
    match /leads/{id}               { allow read, write: if isSignedIn(); }
    match /customers/{id}           { allow read, write: if isSignedIn(); }
    match /parts/{id}               { allow read, write: if isSignedIn(); }
    match /quotes/{id}              { allow read, write: if isSignedIn(); }
    match /tasks/{id}               { allow read, write: if isSignedIn(); }
    match /complaints/{id}          { allow read, write: if isSignedIn(); }
    match /sales_orders/{id}        { allow read, write: if isSignedIn(); }
    match /salesOrders/{id}         { allow read, write: if isSignedIn(); }
    match /invoices/{id}            { allow read, write: if isSignedIn(); }
    match /employees/{id}           { allow read, write: if isSignedIn(); }
    match /departments/{id}         { allow read, write: if isSignedIn(); }
    match /debtors/{id}             { allow read, write: if isSignedIn(); }
    match /targets/{id}             { allow read, write: if isSignedIn(); }
    match /forecasts/{id}           { allow read, write: if isSignedIn(); }
    match /approvals/{id}           { allow read, write: if isSignedIn(); }
    match /approvalRequests/{id}    { allow read, write: if isSignedIn(); }
    match /design_reviews/{id}      { allow read, write: if isSignedIn(); }
    match /feasibility_forms/{id}   { allow read, write: if isSignedIn(); }
    match /technical_templates/{id} { allow read, write: if isSignedIn(); }
    match /backups/{id}             { allow read, write: if isSignedIn(); }
    match /monthlyTargets/{id}      { allow read, write: if isSignedIn(); }
    match /industries/{id}          { allow read, write: if isSignedIn(); }
    match /customer_types/{id}      { allow read, write: if isSignedIn(); }

    // Safety net — any new collection added later works immediately
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
